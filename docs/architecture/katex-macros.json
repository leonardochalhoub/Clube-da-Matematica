{
  "_meta": {
    "description": "Macros globais KaTeX do Clube da Matemática. Importadas via rehype-katex config. Toda fórmula deve usar a macro, nunca a expansão.",
    "convention": "ISO 80000-2"
  },

  "\\R": "\\mathbb{R}",
  "\\C": "\\mathbb{C}",
  "\\N": "\\mathbb{N}",
  "\\Z": "\\mathbb{Z}",
  "\\Q": "\\mathbb{Q}",

  "\\E": "\\mathbb{E}",
  "\\Prob": "\\mathbb{P}",
  "\\Var": "\\operatorname{Var}",
  "\\Cov": "\\operatorname{Cov}",
  "\\Cor": "\\operatorname{Cor}",

  "\\d": "\\mathrm{d}",
  "\\e": "\\mathrm{e}",
  "\\eps": "\\varepsilon",

  "\\norm": "\\left\\|#1\\right\\|",
  "\\abs": "\\left|#1\\right|",
  "\\set": "\\left\\{#1\\right\\}",

  "\\diff": "\\frac{\\d#1}{\\d#2}",
  "\\pdiff": "\\frac{\\partial#1}{\\partial#2}",
  "\\inv": "#1^{-1}",
  "\\T": "^{\\top}",

  "\\Real": "\\operatorname{Re}",
  "\\Imag": "\\operatorname{Im}",

  "\\indep": "\\perp\\!\\!\\!\\perp",
  "\\given": "\\,\\vert\\,",
  "\\half": "\\tfrac{1}{2}",
  "\\third": "\\tfrac{1}{3}",
  "\\quarter": "\\tfrac{1}{4}"
}
